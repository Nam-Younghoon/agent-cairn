# .env.example — 하네스 기본 템플릿
# 실제 값은 로컬 .env 또는 시크릿 매니저에서 주입. 레포지토리에 절대 커밋하지 않는다.
# 신규 환경변수를 추가할 때는 반드시 이 파일도 같은 커밋에 포함한다.

# === 공통 ===
NODE_ENV=development        # development | test | production
LOG_LEVEL=info              # trace | debug | info | warn | error

# === 백엔드 (Express) ===
PORT=3000
DATABASE_URL=
JWT_SECRET=
CORS_ORIGIN=

# === 웹 프론트엔드 (Next.js) ===
# 서버 전용
API_BASE_URL=
# 클라이언트 노출 (비밀값 금지)
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_API_BASE_URL=

# === 모바일 (Flutter) ===
# --dart-define 으로 주입되는 키 목록을 주석으로 관리
# FLUTTER_API_BASE_URL=
# FLUTTER_SENTRY_DSN=
